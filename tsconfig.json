{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "src/*": ["projects/src/*"],
      "@app/*": ["projects/src/app/*"],
      "@common/*": ["projects/src/common/*"],
      "@lib/*": ["projects/src/lib/*"],
      "@conf": ["projects/src/conf/index.ts"],
      "@conf/*": ["projects/src/conf/*"],
      "@env/*": ["projects/src/environments/*"]
    },
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true
  },
  "include": ["projects/src/**/*.ts", "projects/src/**/*.d.ts"],
  "exclude": ["**/*.spec.ts", "node_modules", "dist", "build"]
}
